# AdvantShop — бэкенд каталога и заказов для headless-витрины ШАРОДУВЫ
# Документация: https://www.advantshop.net/help/pages/how-to-use-api

# URL магазина AdvantShop — для API используйте http:// (не https), если иначе 405/406
ADVANTSHOP_BASE_URL=http://shop.example.ru
# ADVANTSHOP_BASE_URL=https://s4.advantme.ru/your-shop-slug
# Если https не работает, явно задайте http:
# ADVANTSHOP_API_BASE_URL=http://shop.example.ru

# Server API key — вкладка «API» (категории, заказы)
ADVANTSHOP_SERVER_API_KEY=your_server_api_key

# Client API key — вкладка «API с авторизацией» (каталог, товары)
ADVANTSHOP_CLIENT_API_KEY=your_client_api_key

# Legacy alias (optional)
# ADVANTSHOP_API_KEY=your_server_api_key

# Slug коллекции на фронте → urlPath категории в AdvantShop (последний сегмент URL)
# Коллекции = категории каталога; чипы в блоке «Каталог» — теги товаров
# JSON (локально) или CSV без кавычек (Amvera)
ADVANTSHOP_CATEGORY_MAP={"nabory-sharov-bazovye":"nabory-sharov-bazovye","bazovyi-premium":"bazovyi-premium","premium-shary":"premium-shary","shary-pod-potolok-1":"shary-pod-potolok-1","oblaka-iz-5-sharov-bez-gruzov":"oblaka-iz-5-sharov-bez-gruzov","fontany-iz-7-sharov":"fontany-iz-7-sharov","fontany-iz-sharov-1":"fontany-iz-sharov-1","dlya-devochek-1":"dlya-devochek-1","dlya-malchikov-1":"dlya-malchikov-1","dlya-nee":"dlya-nee","dlya-nego":"dlya-nego","bolshie-shary-bubble":"bolshie-shary-bubble","shary-gigant-s-nadpisyami-1":"shary-gigant-s-nadpisyami-1","shary-na-devichnik":"shary-na-devichnik","set-s-tsifroi":"set-s-tsifroi","1-godik-1":"1-godik-1","korobki-s-sharami":"korobki-s-sharami","dlya-novorozhdennykh":"dlya-novorozhdennykh","dlya-vliublennykh":"dlya-vliublennykh","pirotekhnika":"pirotekhnika"}

# Кэш каталога (секунды)
ADVANTSHOP_REVALIDATE_SECONDS=300

# Cookie для магазина в режиме «в разработке» (прокси картинок)
# ADVANTSHOP_STORE_COOKIE=your_store_session_cookie

# Таймаут HTTP к AdvantShop (мс)
# ADVANTSHOP_FETCH_TIMEOUT_MS=55000

# Метка источника заказа в админке AdvantShop
# ADVANTSHOP_ORDER_SOURCE=sharoduwi.ru

# URL сайта (для ссылок в письмах/оплате)
SITE_URL=https://sharoduwi.ru

# --- Amvera ---
# Задайте переменные в панели Amvera: Приложение → Переменные окружения.
# ADVANTSHOP_CATEGORY_MAP на Amvera удобнее в CSV (без JSON-кавычек):
# nabory-sharov-bazovye:nabory-sharov-bazovye,bazovyi-premium:bazovyi-premium,set-s-tsifroi:set-s-tsifroi,...
# Не добавляйте в UI Amvera артеfact override «* -> /» — используйте amvera.yaml из репозитория.
# Команда запуска в UI Amvera должна быть ПУСТАЯ или из amvera.yaml (Docker → node server.js).
# Не указывайте npm run dev — это только для локальной разработки.
