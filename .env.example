# AdvantShop — бэкенд каталога и заказов для headless-витрины ШАРОДУВЫ
# Документация: https://www.advantshop.net/help/pages/how-to-use-api

# URL магазина AdvantShop (свой домен или технический с путём магазина)
ADVANTSHOP_BASE_URL=https://s4.advantme.ru/your-shop-slug
# ADVANTSHOP_BASE_URL=https://shop.example.ru

# Server API key — вкладка «API» (категории, заказы)
ADVANTSHOP_SERVER_API_KEY=your_server_api_key

# Client API key — вкладка «API с авторизацией» (каталог, товары)
ADVANTSHOP_CLIENT_API_KEY=your_client_api_key

# Legacy alias (optional)
# ADVANTSHOP_API_KEY=your_server_api_key

# Slug коллекции на фронте → urlPath категории в AdvantShop (последний сегмент URL)
# Коллекции = категории каталога; чипы в блоке «Каталог» — теги товаров
# JSON (локально) или CSV без кавычек (Amvera): nabory-bazovye:nabory-bazovye,set-s-cifroy:set-s-cifroy
ADVANTSHOP_CATEGORY_MAP={"nabory-bazovye":"nabory-bazovye","bazovyy-premium":"bazovyy-premium","premium-shary":"premium-shary","shary-pod-potolok":"shary-pod-potolok","oblaka-5":"oblaka-5","fontany-7":"fontany-7","fontany":"fontany","dlya-devochek":"dlya-devochek","dlya-malchikov":"dlya-malchikov","dlya-nee":"dlya-nee","dlya-nego":"dlya-nego","shary-giant":"shary-giant","shary-giant-nadpisi":"shary-giant-nadpisi","shary-devichnik":"shary-devichnik","set-s-cifroy":"set-s-cifroy","1-godik":"1-godik","korobki":"korobki","dlya-novorozhdennyh":"dlya-novorozhdennyh","dlya-vlyublennyh":"dlya-vlyublennyh","pirotekhnika":"pirotekhnika"}

# Кэш каталога (секунды)
ADVANTSHOP_REVALIDATE_SECONDS=300

# Cookie для магазина в режиме «в разработке» (прокси картинок)
# ADVANTSHOP_STORE_COOKIE=your_store_session_cookie

# Таймаут HTTP к AdvantShop (мс)
# ADVANTSHOP_FETCH_TIMEOUT_MS=55000

# Метка источника заказа в админке AdvantShop
# ADVANTSHOP_ORDER_SOURCE=sharoduwi.ru

# URL сайта (для ссылок в письмах/оплате)
SITE_URL=https://sharoduwi.ru

# --- Amvera ---
# Задайте переменные в панели Amvera: Приложение → Переменные окружения.
# ADVANTSHOP_CATEGORY_MAP на Amvera удобнее в CSV (без JSON-кавычек):
# nabory-bazovye:nabory-bazovye,bazovyy-premium:bazovyy-premium,set-s-cifroy:set-s-cifroy,...
# Не добавляйте в UI Amvera артеfact override «* -> /» — используйте amvera.yaml из репозитория.
